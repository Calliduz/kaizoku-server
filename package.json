{
  "name": "kaizoku-server",
  "version": "1.0.0",
  "description": "Kaizoku — Anime streaming platform backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "scrape": "node -e \"require('./src/scrapers/engine').runScrape()\"",
    "seed": "node src/scripts/seed.js",
    "postinstall": "npx puppeteer browsers install chrome"
  },
  "keywords": [
    "anime",
    "streaming",
    "scraper"
  ],
  "license": "MIT",
  "dependencies": {
    "@consumet/extensions": "^1.8.8",
    "aniwatch": "^2.27.9",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fuzzball": "^2.1.3",
    "helmet": "^8.0.0",
    "mongoose": "^8.10.1",
    "morgan": "^1.10.0",
    "puppeteer": "^24.4.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
